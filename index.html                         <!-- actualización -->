<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Herrera Tech Academy</title>

<style>
body{margin:0;font-family:Arial;background:#0b1d3a;color:white}
header{background:#07142b;padding:15px;display:flex;align-items:center;justify-content:center;gap:15px}
header img{width:60px}
nav{background:#07142b;padding:10px;text-align:center}
nav a{color:white;margin:0 15px;text-decoration:none}

.hero{
height:300px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
background:linear-gradient(to right,#0b1d3a,#123a7a);
}

.row{padding:20px}
.slider{display:flex;overflow-x:auto;padding:10px}

.card{
min-width:250px;
background:#142b57;
margin:10px;
border-radius:10px;
overflow:hidden;
position:relative;
transition:0.4s
}

.card img{
width:100%;
height:150px;
object-fit:cover;
transition:0.4s
}

.preview{
position:absolute;
top:0;
left:0;
width:100%;
height:150px;
display:none;
}

.card:hover .preview{display:block;}
.card:hover img{opacity:0;}
.card:hover{transform:scale(1.1);z-index:2}

.card-content{padding:15px}

.btn{
background:#1e90ff;
border:none;
padding:8px;
margin-top:5px;
color:white;
cursor:pointer;
width:100%
}

iframe{width:80%;height:400px}

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
padding:15px;
border-radius:50%;
text-decoration:none
}
</style>
</head>

<body>

<header>
<img src="logo.png">
<div>
<h1>Herrera Tech Academy</h1>
<p style="color:#1e90ff">Formando profesionales en tecnología</p>
</div>
</header>

<nav>
<a href="#">Inicio</a>
<a href="#">Cursos</a>
</nav>

<section class="hero">
<h1>Aprende Tecnología Profesional</h1>
<p>Plataforma tipo Netflix</p>
</section>

<div class="row">
<h2>Cursos Populares</h2>
<div class="slider">

<div class="card">
<img src="https://images.unsplash.com/photo-1518770660439-4636190af475">
<iframe class="preview" src="https://www.youtube.com/embed/O5nskjZ_GoI?autoplay=1&mute=1"></iframe>
<div class="card-content">
<h3>Sistemas</h3>
<button class="btn" onclick="ver('sistemas')">Ver</button>
</div>
</div>

</div>
</div>

<div id="video" style="text-align:center"></div>

<a class="whatsapp" href="https://wa.me/18499251500" target="_blank">💬</a>

<script>
function ver(curso){
let v=document.getElementById('video');
v.innerHTML=`<iframe src="https://www.youtube.com/embed/O5nskjZ_GoI"></iframe>`;
}
</script>

</body>
</html>
